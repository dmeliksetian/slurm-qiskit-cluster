# =============================================================================
# slurm-qiskit-cluster .gitignore
# =============================================================================

# Credentials — never commit
cluster/config/qrmi_config*.json
cluster/config/slurm.conf
cluster/config/gres.conf
cluster/docker-compose.yml

# Shared volume contents — built at runtime, not tracked
shared/pyenv/
shared/data/
shared/examples/
# QRMI build artifacts
shared/qrmi/target/

# SPANK plugin build artifacts
shared/spank-plugins/plugins/spank_qrmi/build/

# Environment file
.env
session-context.md
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.whl

# Editor and OS
.venv
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.bak
paper/

# Podman / Docker
*.tar
