# =============================================================================
# slurm-qiskit-cluster — environment configuration
# Copy this file to .env and set values before running setup scripts.
#
#   cp .env.example .env
#
# .env is gitignored — never commit it.
# =============================================================================

# ── Slurm ─────────────────────────────────────────────────────────────────────
# Git tag from https://github.com/SchedMD/slurm/tags
# Must match the version used to build spank_qrmi.so (handled automatically
# by the builder container since it builds both from the same image).
SLURM_TAG=slurm-23-11-9-1

# ── Image tagging ─────────────────────────────────────────────────────────────
# Tag applied to all built images. Use a version string when releasing,
# 'latest' is fine for local development.
IMAGE_TAG=latest

# ── Build versions ─────────────────────────────────────────────────────────────
# These are the confirmed working versions. Change only if you need to upgrade.
GOSU_VERSION=1.17
MY_PMIX_VERSION=4.2.9
OPENMPI_VERSION=4.1.6

# ── CUDA ──────────────────────────────────────────────────────────────────────
# CUDA version installed in the gpu and quantum-gpu stages.
# Must match the CUDA version available from NVIDIA's Rocky Linux 9 repo.
# Check available versions at:
#   https://developer.download.nvidia.com/compute/cuda/repos/rhel9/x86_64/
CUDA_VERSION=12-9

# ── Node configuration ────────────────────────────────────────────────────────
# Number of CPU cores to advertise per compute node.
# Should match the CPUs field in slurm.conf.
# Default matches the example slurm.conf (2 CPUs per node).
SLURM_CPUS_PER_NODE=2
